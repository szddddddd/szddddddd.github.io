---
import Section from './Section.astro';
import { bme1312Proj2CourseProject, profile } from '../data/profile';
import { getCopy, type Lang } from '../i18n';
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props as Props;
const t = getCopy(lang);
const copy = t.bme1312Proj2;
const project = bme1312Proj2CourseProject;
const typeLabel = project.type?.[lang] ?? t.common.courseProject;
const courseLabel = typeof project.course === 'string' ? project.course : project.course?.[lang] ?? 'BME1312';
const titleParts = copy.hero.title.split(': ');
const titleLines = titleParts.length > 1 ? [`${titleParts[0]}:`, titleParts.slice(1).join(': ')] : [copy.hero.title];
const resolveLink = (value: string | { en: string; zh: string } | undefined) => {
  if (!value) return '';
  return typeof value === 'string' ? value : value[lang];
};
const reportHref = resolveLink(project.links.report);
const slidesHref = resolveLink(project.links.slides);
const details = [
  { label: copy.labels.course, value: courseLabel },
  { label: copy.labels.type, value: typeLabel },
  {
    label: copy.labels.task,
    value: lang === 'zh' ? 'BraTS 风格多模态脑胶质瘤子区域分割' : 'BraTS-style multi-modal glioma subregion segmentation',
  },
  { label: copy.labels.modalities, value: 'T1 · T1ce · T2 · FLAIR' },
  { label: copy.labels.targetRegions, value: 'WT · TC · ET' },
];
---

<BaseLayout lang={lang} page="projectBme1312Proj2" title={copy.metaTitle} description={copy.metaDescription}>
  <article class="project-detail bme1312-proj2-detail">
    <header class="project-detail-hero">
      <div class="detail-hero-copy reveal-block">
        <p class="eyebrow">{copy.hero.eyebrow}</p>
        <h1 class="project-detail-title">
          {titleLines.map((line) => <span>{line}</span>)}
        </h1>
        <p class="detail-subtitle wide-subtitle">{copy.hero.subtitle}</p>
        <p class="detail-affiliation">{copy.hero.affiliation}</p>
        <ul class="tag-list expanded-tags detail-tags" aria-label="Project metadata tags">
          {copy.metadata.map((item) => <li>{item}</li>)}
        </ul>
        <div class="hero-actions detail-actions">
          <a class="button button-secondary" href={`mailto:${profile.email}`}>{t.hero.emailAction}</a>
          <a class="button button-secondary" href={reportHref}>{t.projects.labels.report}</a>
          <a class="button button-secondary" href={slidesHref}>{t.projects.labels.slides}</a>
        </div>
      </div>
      <figure class="detail-hero-figure reveal-block">
        <img src={copy.gallery[2].src} alt={copy.gallery[2].alt} loading="eager" />
        <figcaption>{copy.gallery[2].caption}</figcaption>
      </figure>
    </header>

    <section class="metadata-grid" aria-label="Project metadata">
      {details.map((item) => (
        <article>
          <span>{item.label}</span>
          <strong>{item.value}</strong>
        </article>
      ))}
    </section>

    <Section id="overview" eyebrow="BME1312" title={copy.sections.overview} intro={copy.overview}>
      <div class="detail-two-column">
        <div class="panel project-summary-panel">
          <p class="panel-label">{copy.labels.summary}</p>
          <ul class="interest-list">
            {copy.overviewBullets.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="metric-cards metric-cards-three region-card-grid" aria-label={copy.labels.targetRegions}>
          {copy.regionCards.map((item) => (
            <article>
              <span>{item.label}</span>
              <strong>{item.value}</strong>
              <p>{item.note}</p>
            </article>
          ))}
        </div>
      </div>
    </Section>

    <Section id="method" title={copy.sections.method} intro={copy.methodIntro}>
      <div class="method-grid bme1312-proj2-method-grid">
        {copy.methodCards.map((card) => (
          <article class="method-card">
            <p class="panel-label">{copy.labels.pipeline}</p>
            <h3>{card.title}</h3>
            <ul class="interest-list">
              {card.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </Section>

    <Section id="key-results" title={copy.sections.results} intro={copy.resultsIntro}>
      <div class="metric-table" role="table" aria-label="HBA-VAN glioma segmentation quantitative comparison">
        <div class="metric-row metric-row-6 metric-head" role="row">
          {copy.resultColumns.map((column) => <span role="columnheader">{column}</span>)}
        </div>
        {copy.resultRows.map((row) => (
          <div class="metric-row metric-row-6" role="row">
            {row.map((cell, index) => <span role="cell" class:list={{ 'metric-model': index === 0 }}>{cell}</span>)}
          </div>
        ))}
      </div>
      <div class="metric-cards" aria-label={copy.labels.result}>
        {copy.metricCards.map((item) => (
          <article>
            <span>{item.label}</span>
            <strong>{item.value}</strong>
            <p>{item.note}</p>
          </article>
        ))}
      </div>
      <div class="panel highlight-panel">
        <p class="panel-label">{copy.labels.result}</p>
        <ul class="highlight-list">
          {copy.resultHighlights.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </Section>

    <Section id="visuals" title={copy.sections.visuals} intro={copy.galleryIntro}>
      <div class="gallery-grid bme1312-proj2-gallery">
        {copy.gallery.map((item) => (
          <figure class="detail-figure">
            <img src={item.src} alt={item.alt} loading="lazy" />
            <figcaption>{item.caption}</figcaption>
          </figure>
        ))}
      </div>
    </Section>

    <Section id="contribution" title={copy.sections.contribution}>
      <div class="panel narrative-panel">
        <ul class="interest-list">
          {copy.contributionBullets.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </Section>

    <Section id="links" title={copy.sections.links} intro={copy.linksIntro}>
      <div class="panel narrative-panel asset-link-panel">
        <p>{copy.courseContext}</p>
        <div class="hero-actions detail-actions">
          <a class="button button-secondary" href={reportHref}>{t.projects.labels.report}</a>
          <a class="button button-secondary" href={slidesHref}>{t.projects.labels.slides}</a>
        </div>
      </div>
    </Section>
  </article>
</BaseLayout>
