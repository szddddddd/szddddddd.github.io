---
import type { LinkValue, Project } from '../../data/projects';
import type { Lang } from '../../i18n';

interface Props {
  project: Project;
  lang: Lang;
  labels: {
    details: string;
    report: string;
    shadertoy: string;
    paper: string;
    code: string;
    demo: string;
    readme: string;
    slides: string;
    role: string;
  };
}

const { project, lang, labels } = Astro.props as Props;
const title = project.title[lang];
const summary = project.summary[lang];
const role = project.role?.[lang];
const typeLabel = project.type?.[lang];
const courseLabel = typeof project.course === 'string' ? project.course : project.course?.[lang];
const isSi100bProject = project.id === 'si100b';
const isAlternating = Number(project.number) % 2 === 0;
const resolveLink = (value: LinkValue | undefined) => (typeof value === 'string' ? value : value?.[lang] ?? '');
const detailHref = resolveLink(project.links.details);
const links = [
  { label: labels.shadertoy, value: project.links.shadertoy },
  { label: labels.report, value: project.links.report },
  { label: labels.slides, value: project.links.slides },
  { label: labels.code, value: project.links.code },
  { label: labels.readme, value: project.links.readme },
  { label: labels.paper, value: project.links.paper },
  { label: labels.demo, value: project.links.demo },
]
  .map((link) => ({ label: link.label, href: resolveLink(link.value) }))
  .filter((link) => Boolean(link.href));
const isExternal = (href: string) => href.startsWith('http');
const requiresDocumentNavigation = (href: string) => isExternal(href) || /\.(?:pdf|pptx)(?:$|[?#])/i.test(href);
---

<article
  class:list={[
    'project-row',
    'reveal-card',
    detailHref && 'is-clickable',
    isSi100bProject && 'si100b-project-preview',
    isAlternating && 'project-row--reverse',
  ]}
  data-rsui-project={project.slug}
  data-project-categories={project.categories.join(' ')}
  style={`--project-accent:${project.spatialAccent};`}
>
  {
    detailHref && (
      <a class="card-cover-link" href={detailHref} aria-label={`${labels.details}: ${title}`}>
        <span class="sr-only">{labels.details}: {title}</span>
      </a>
    )
  }

  <div class="project-row-media">
    <img src={project.cover.src} alt={project.cover.alt[lang]} loading="lazy" decoding="async" transition:name={`project-cover-${project.slug}`} />
  </div>

  <div class="project-row-main">
    <div class="project-row-meta">
      <span>{project.number}</span>
      <span>{project.year}</span>
      {typeLabel && <span>{typeLabel}</span>}
    </div>

    <h2 transition:name={`project-title-${project.slug}`}>{title}</h2>

    {courseLabel && <p class="project-row-context">{courseLabel}</p>}
    <p class="project-row-description">{summary}</p>
    {role && <p class="project-row-role"><strong>{labels.role}:</strong> {role}</p>}

    <div class="project-row-tags" aria-label={`${title} tags`}>
      {project.displayTags.map((tag) => <span>{tag[lang]}</span>)}
    </div>

    {
      links.length > 0 && (
        <div class="project-row-links" aria-label={`${title} links`}>
          {links.map(({ label, href }) => (
            <a
              href={href}
              target={isExternal(href) ? '_blank' : undefined}
              rel={isExternal(href) ? 'noreferrer' : undefined}
              data-astro-reload={requiresDocumentNavigation(href) ? '' : undefined}
            >
              {label}
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>
