---
import type { Lang, Project } from '../data/profile';

interface Props {
  project: Project;
  lang: Lang;
  labels: {
    details: string;
    report: string;
    shadertoy: string;
    paper: string;
    code: string;
    demo: string;
  };
  comingSoon: string;
  placeholder: string;
}

const { project, lang, labels, comingSoon, placeholder } = Astro.props as Props;
const title = project.title[lang];
const description = project.description[lang];
const year = project.year === 'Coming soon' ? comingSoon : project.year;
const typeLabel = project.type?.[lang] ?? placeholder;
const courseLabel = typeof project.course === 'string' ? project.course : project.course?.[lang];
const hasDetailLinks = Boolean(project.links.details || project.links.report);
const links = hasDetailLinks
  ? [
      { key: 'details', label: labels.details, value: project.links.details },
      ...(project.links.shadertoy !== undefined ? [{ key: 'shadertoy', label: labels.shadertoy, value: project.links.shadertoy }] : []),
      ...(project.links.report !== undefined ? [{ key: 'report', label: labels.report, value: project.links.report }] : []),
      ...(project.links.code !== undefined ? [{ key: 'code', label: labels.code, value: project.links.code }] : []),
    ]
  : [
      { key: 'paper', label: labels.paper, value: project.links.paper },
      { key: 'code', label: labels.code, value: project.links.code },
      { key: 'demo', label: labels.demo, value: project.links.demo },
    ];
const resolveLink = (value: typeof links[number]['value']) => {
  if (!value) return '';
  return typeof value === 'string' ? value : value[lang];
};
const isUrl = (value: string) => value.startsWith('http') || value.startsWith('/') || value.startsWith('mailto:');
---

<article class="project-card reveal-card">
  <div class="project-media" aria-hidden="true">
    {project.image ? <img src={project.image} alt="" loading="lazy" /> : <div class="project-field"><span></span><span></span><span></span></div>}
  </div>
  <div class="card-topline">
    <span>{year}</span>
    <span>{typeLabel}</span>
  </div>
  <h3>{title}</h3>
  {courseLabel && <p class="project-course">{courseLabel}</p>}
  <p>{description}</p>
  <ul class="tag-list" aria-label={`${title} tags`}>
    {project.tags.map((tag) => <li>{tag}</li>)}
  </ul>
  <div class="inline-links" aria-label={`${title} links`}>
    {
      links.map(({ label, value }) => {
        const href = resolveLink(value);
        return href && isUrl(href) ? (
          <a href={href} target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noreferrer' : undefined}>
            {label}
          </a>
        ) : (
          <span class="disabled-link">{label}: {comingSoon}</span>
        );
      })
    }
  </div>
</article>
