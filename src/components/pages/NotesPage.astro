---
import type { Lang } from '../../i18n';
import { getCopy } from '../../i18n';
import { noteEntries } from '../../data/notes';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props as Props;
const t = getCopy(lang);
const entryCount = String(noteEntries.length).padStart(2, '0');
---

<div class="page-stack notes-page">
  <section class="page-hero page-hero-compact" aria-labelledby="notes-page-title">
    <p class="eyebrow" transition:name="page-index">05 / {t.nav.notes}</p>
    <h1 id="notes-page-title" transition:name="page-main-title">{t.notes.pageTitle}</h1>
    <p>{t.notes.intro}</p>
    <div class="notes-network-plot" aria-hidden="true"><i></i><i></i><i></i><i></i><b></b><b></b><b></b></div>
  </section>

  <section class="section notes-library" aria-labelledby="notes-index-title">
    <aside class="section-heading notes-index-rail">
      <div>
        <p class="panel-label">{entryCount} / {t.notes.entryCount}</p>
        <h2 id="notes-index-title">{t.notes.indexTitle}</h2>
      </div>

      <nav aria-labelledby="notes-index-title">
        <ol class="notes-index-list">
          {
            noteEntries.map((entry, index) => (
              <li>
                <a href={`#note-${entry.id}`}>
                  <span class="notes-index-list__number" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
                  <span class="notes-index-list__copy">
                    <strong>{entry.title[lang]}</strong>
                    <small>{entry.format[lang]} · {entry.date}</small>
                  </span>
                </a>
              </li>
            ))
          }
        </ol>
      </nav>

      <div class="notes-index-rail__topics">
        <p class="panel-label">{t.notes.topicsTitle}</p>
        <ul class="tag-list" aria-label={t.notes.topicsTitle}>
          {t.notes.topics.map((topic) => <li>{topic}</li>)}
        </ul>
      </div>
    </aside>

    <div class="section-body notes-entry-list" data-notes-index>
      {
        noteEntries.map((entry) => (
          <article id={`note-${entry.id}`} class="notes-entry">
            <p class="panel-label">{entry.format[lang]} · {entry.date}</p>
            <h2>{entry.title[lang]}</h2>
            <p>{entry.summary[lang]}</p>
            <ul class="tag-list" aria-label={`${entry.title[lang]} ${t.notes.topicsTitle}`}>
              {entry.topics[lang].map((topic) => <li>{topic}</li>)}
            </ul>
            <a class="text-link" href={entry.href} data-astro-reload>{t.notes.readEntry}</a>
          </article>
        ))
      }
    </div>
  </section>
</div>
