---
import type { Lang, PageKey } from '../../i18n';
import { getRouteForPage } from '../../config/routes';
import { profile } from '../../data/profile';
import SpatialRibbon from '../navigation/SpatialRibbon.astro';
import SpatialUIRoot from '../spatial/SpatialUIRoot.astro';

interface Props {
  lang: Lang;
  page: PageKey;
}

const { lang, page } = Astro.props as Props;
const route = getRouteForPage(page);
---

<div class="spatial-ui-persistence" transition:persist="spatial-ui">
  <SpatialUIRoot />
</div>
<SpatialRibbon lang={lang} page={page} />
<main
  id="main-content"
  class:list={['site-main', page === 'home' && 'site-main--home']}
  tabindex="-1"
  data-page-key={page}
  data-spatial-route={route.id}
  style={`--page-accent:${route.accent};`}
>
  <slot />
</main>
<footer class="site-footer">
  <p>© {new Date().getFullYear()} {lang === 'zh' ? profile.nameZh : profile.nameEn}. {lang === 'zh' ? '使用 Astro 构建。' : 'Built with Astro.'}</p>
</footer>
