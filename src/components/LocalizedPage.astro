---
import Hero from './Hero.astro';
import ProjectCard from './ProjectCard.astro';
import ProjectIndexRow from './ProjectIndexRow.astro';
import PublicationItem from './PublicationItem.astro';
import Section from './Section.astro';
import { profile } from '../data/profile';
import { getCopy, getPath, type Lang, type PageKey } from '../i18n';
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  lang: Lang;
  page: PageKey;
}

const { lang, page } = Astro.props as Props;
const t = getCopy(lang);
const display = profile.display[lang];

const titles: Record<PageKey, string> = {
  home: t.meta.siteTitle,
  about: `${t.nav.about} — ${display.name}`,
  projects: `${t.nav.projects} — ${display.name}`,
  projectSi140a: t.si140a.metaTitle,
  projectBme1312: t.bme1312.metaTitle,
  projectBme1312Proj2: t.bme1312Proj2.metaTitle,
  projectCs182: t.cs182.metaTitle,
  projectSi100b: t.si100b.metaTitle,
  projectArts1308: t.arts1308.metaTitle,
  publications: `${t.nav.publications} — ${display.name}`,
  coursework: `${t.nav.coursework} — ${display.name}`,
  notes: `${t.nav.notes} — ${display.name}`,
};

const descriptions: Record<PageKey, string> = {
  home: t.meta.description,
  about: t.about.intro,
  projects: t.projects.fullIntro,
  projectSi140a: t.si140a.metaDescription,
  projectBme1312: t.bme1312.metaDescription,
  projectBme1312Proj2: t.bme1312Proj2.metaDescription,
  projectCs182: t.cs182.metaDescription,
  projectSi100b: t.si100b.metaDescription,
  projectArts1308: t.arts1308.metaDescription,
  publications: t.publications.intro,
  coursework: t.coursework.intro,
  notes: t.notes.intro,
};

const identityRows = [
  { label: t.hero.identityLabels.role, value: display.role },
  { label: t.hero.identityLabels.university, value: display.university },
  { label: t.hero.identityLabels.lab, value: profile.lab },
  { label: t.hero.identityLabels.major, value: display.major },
];

---

<BaseLayout lang={lang} page={page} title={titles[page]} description={descriptions[page]}>
  {page === 'home' && (
    <div class="page-stack">
      <Hero lang={lang} />

      <Section id="research" eyebrow={t.projects.eyebrow} title={t.projects.title} intro={t.projects.intro}>
        <div class="project-grid">
          {profile.projects.map((project) => <ProjectCard project={project} lang={lang} labels={t.projects.labels} comingSoon={t.common.comingSoon} placeholder={t.common.placeholder} />)}
        </div>
        <a class="text-link" href={getPath(lang, 'projects')}>{t.projects.viewAll} →</a>
      </Section>

      <Section id="publications" eyebrow={t.publications.eyebrow} title={t.publications.title} intro={t.publications.intro}>
        <div class="empty-state compact-empty">
          <span>{t.common.comingSoon}</span>
          <p>{t.publications.empty}</p>
        </div>
      </Section>

    </div>
  )}

  {page === 'about' && (
    <div class="page-stack">
      <section class="page-hero page-hero-compact about-page-hero">
        <h1>{t.about.pageTitle}</h1>
        <p>{t.about.intro}</p>
      </section>

      <section class="section about-compact-section">
        <div class="section-body about-compact-layout">
          <article class="panel about-info-card" aria-label={t.about.identityTitle}>
            <dl class="fact-list about-fact-grid">
              {identityRows.map((item) => (
                <div>
                  <dt>{item.label}</dt>
                  <dd>{item.value}</dd>
                </div>
              ))}
            </dl>
          </article>

          <div class="about-interest-block" aria-label={t.about.interestsTitle}>
            <ul class="tag-list about-interest-tags">
              {profile.researchInterests.map((interest) => <li>{interest}</li>)}
            </ul>
          </div>
        </div>
      </section>
    </div>
  )}

  {page === 'projects' && (
    <div class="page-stack">
      <section class="page-hero page-hero-compact">
        <h1>{t.projects.pageTitle}</h1>
        <p>{t.projects.fullIntro}</p>
      </section>

      <Section>
        <div class="project-index">
          {profile.projects.map((project) => <ProjectIndexRow project={project} lang={lang} labels={t.projects.labels} comingSoon={t.common.comingSoon} placeholder={t.common.placeholder} />)}
        </div>
      </Section>
    </div>
  )}

  {page === 'publications' && (
    <div class="page-stack">
      <section class="page-hero page-hero-compact">
        <h1>{t.publications.pageTitle}</h1>
        <p>{t.publications.intro}</p>
      </section>

      <Section>
        {profile.publications.length > 0 ? (
          <div class="publication-list">
            {profile.publications.map((publication) => (
              <PublicationItem publication={publication} labels={t.publications.labels} comingSoon={t.common.comingSoon} />
            ))}
          </div>
        ) : (
          <div class="empty-state">
            <span>{t.common.comingSoon}</span>
            <p>{t.publications.empty}</p>
          </div>
        )}
      </Section>
    </div>
  )}

  {page === 'coursework' && (
    <div class="page-stack">
      <section class="page-hero page-hero-compact">
        <h1>{t.coursework.pageTitle}</h1>
        <p>{t.coursework.mergedIntro}</p>
      </section>

      <Section>
        <div class="empty-state coursework-merged-notice">
          <span>{t.coursework.mergedTitle}</span>
          <p>{t.coursework.mergedIntro}</p>
          <a class="button button-secondary" href={getPath(lang, 'projects')}>{t.coursework.viewProjects}</a>
        </div>
      </Section>
    </div>
  )}

  {page === 'notes' && (
    <div class="page-stack">
      <section class="page-hero page-hero-compact">
        <h1>{t.notes.pageTitle}</h1>
        <p>{t.notes.intro}</p>
      </section>

      <Section>
        <div class="empty-state">
          <span>{t.common.comingSoon}</span>
          <p>{t.notes.empty}</p>
        </div>
      </Section>
    </div>
  )}
</BaseLayout>
