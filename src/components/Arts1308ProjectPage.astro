---
import Section from './Section.astro';
import ShaderWorkCard from './ShaderWorkCard.astro';
import { arts1308CourseProject } from '../data/profile';
import { shadertoyProfileUrl, shadertoyWorks } from '../data/shadertoy';
import { getCopy, type Lang } from '../i18n';
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props as Props;
const t = getCopy(lang);
const copy = t.arts1308;
const project = arts1308CourseProject;
const typeLabel = project.type?.[lang] ?? t.common.courseProject;
const courseValue = lang === 'zh' ? 'ARTS1308 像素着色艺术' : 'ARTS1308 Pixel Shading Art';
const contextValue = lang === 'zh' ? '课程项目 · 上海科技大学' : 'Course Project · ShanghaiTech University';
const details = [
  { label: copy.labels.course, value: courseValue },
  { label: copy.labels.type, value: typeLabel },
  { label: copy.labels.context, value: contextValue },
  { label: copy.labels.account, value: 'szd / Shadertoy' },
];
---

<BaseLayout lang={lang} page="projectArts1308" title={copy.metaTitle} description={copy.metaDescription}>
  <article class="project-detail arts1308-detail">
    <header class="project-detail-hero arts-hero">
      <div class="detail-hero-copy reveal-block">
        <p class="eyebrow">{copy.hero.eyebrow}</p>
        <h1 class="project-detail-title">{copy.hero.title}</h1>
        <p class="detail-subtitle wide-subtitle">{copy.hero.subtitle}</p>
        <p class="detail-affiliation">{copy.hero.affiliation}</p>
        <ul class="tag-list expanded-tags detail-tags" aria-label="Project metadata tags">
          {copy.metadata.map((item) => <li>{item}</li>)}
        </ul>
        <div class="hero-actions detail-actions">
          <a class="button button-secondary" href={shadertoyProfileUrl} target="_blank" rel="noreferrer">{copy.labels.profile}</a>
          <a class="button button-secondary" href="#visual-gallery">{copy.sections.gallery}</a>
          <a class="button button-secondary" href="#course-context">{copy.sections.courseContext}</a>
        </div>
      </div>
      <figure class="detail-hero-figure arts-hero-figure reveal-block">
        <div class="arts-hero-mosaic" aria-label="Selected Shadertoy thumbnails">
          {shadertoyWorks.slice(0, 4).map((work) => <img src={work.thumbnail} alt={`${work.title} thumbnail`} loading="eager" decoding="async" />)}
        </div>
        <figcaption>{copy.hero.subtitle}</figcaption>
      </figure>
    </header>

    <section class="metadata-grid" aria-label="Project metadata">
      {details.map((item) => (
        <article>
          <span>{item.label}</span>
          <strong>{item.value}</strong>
        </article>
      ))}
    </section>

    <Section eyebrow="ARTS1308" title={copy.sections.overview} intro={copy.overview}>
      <div class="detail-two-column">
        <div class="panel project-summary-panel">
          <p class="panel-label">{copy.labels.works}: {shadertoyWorks.length}</p>
          <ul class="interest-list">
            {copy.overviewBullets.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <figure class="detail-figure compact-figure arts-preview-figure">
          <img src={shadertoyWorks[5].thumbnail} alt={`${shadertoyWorks[5].title} thumbnail`} loading="lazy" />
          <figcaption>{shadertoyWorks[5].title}</figcaption>
        </figure>
      </div>
    </Section>

    <Section id="visual-gallery" title={copy.sections.gallery} intro={copy.galleryIntro}>
      <div class="shader-gallery-grid">
        {shadertoyWorks.map((work, index) => (
          <ShaderWorkCard work={work} index={index + 1} labels={copy.labels} />
        ))}
      </div>
    </Section>

    <Section title={copy.sections.technicalFocus}>
      <div class="shader-focus-grid">
        {copy.technicalFocus.map((item) => (
          <article class="method-card shader-focus-card">
            <p class="panel-label">GLSL</p>
            <h3>{item}</h3>
          </article>
        ))}
      </div>
    </Section>

    <Section id="course-context" title={copy.sections.courseContext}>
      <div class="panel narrative-panel">
        <p>{copy.courseContext}</p>
      </div>
    </Section>

    <Section title={copy.sections.relatedLinks}>
      <div class="portal-grid arts-links-grid">
        {copy.relatedLinks.map((item) => (
          <a class="portal-card" href={item.href} target="_blank" rel="noreferrer">
            <span>{item.title}</span>
            <p>{item.text}</p>
          </a>
        ))}
      </div>
    </Section>
  </article>

  <script>
    document.querySelectorAll('details[data-shader-embed]').forEach((details) => {
      details.addEventListener('toggle', () => {
        if (!(details instanceof HTMLDetailsElement) || !details.open) return;
        const iframe = details.querySelector('iframe[data-src]');
        if (!(iframe instanceof HTMLIFrameElement) || iframe.src) return;
        const src = iframe.dataset.src;
        if (src) iframe.src = src;
      });
    });
  </script>
</BaseLayout>
