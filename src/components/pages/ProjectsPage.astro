---
import type { Lang } from '../../i18n';
import { getCopy } from '../../i18n';
import { projects, type ProjectCategory } from '../../data/projects';
import ProjectIndexRow from '../projects/ProjectIndexRow.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props as Props;
const t = getCopy(lang);
const workCount = String(projects.length).padStart(2, '0');
const pageTitle = lang === 'en'
  ? `${t.projects.fullTitle.toUpperCase()} / ${workCount} ${t.projects.indexTitle.toUpperCase()}`
  : `${t.projects.fullTitle} / ${workCount} ${t.projects.indexTitle}`;
const filterDefinitions = [
  { id: 'all', label: t.projects.filters.all, description: t.projects.index.descriptions.all, preview: projects[0] },
  { id: '3d-vision', label: t.projects.filters.vision, description: t.projects.index.descriptions['3d-vision'], preview: projects.find((project) => project.categories.includes('3d-vision'))! },
  { id: 'medical-imaging', label: t.projects.filters.medical, description: t.projects.index.descriptions['medical-imaging'], preview: projects.find((project) => project.categories.includes('medical-imaging'))! },
  { id: 'creative-coding', label: t.projects.filters.creative, description: t.projects.index.descriptions['creative-coding'], preview: projects.find((project) => project.categories.includes('creative-coding'))! },
  { id: 'coursework', label: t.projects.filters.coursework, description: t.projects.index.descriptions.coursework, preview: projects[0] },
] as const;
const filters = filterDefinitions.map((filter) => ({
  ...filter,
  count: filter.id === 'all' ? projects.length : projects.filter((project) => project.categories.includes(filter.id as ProjectCategory)).length,
}));
---

<div class="page-stack projects-page" data-project-filtering>
  <section class="page-hero page-hero-compact" aria-labelledby="projects-page-title">
    <p class="eyebrow" transition:name="page-index">02 / {t.nav.projects}</p>
    <h1 id="projects-page-title" transition:name="page-main-title">{pageTitle}</h1>
    <p>{t.projects.fullIntro}</p>
  </section>

  <section class="projects-research-index" aria-label={t.projects.index.railLabel}>
    <aside class="project-index-rail">
      <div class="project-index-rail__header">
        <p class="eyebrow">02 / {t.nav.projects}</p>
        <p class="project-index-rail__current" data-project-current-filter>{filters[0].label}</p>
        <p class="project-index-rail__count"><span data-project-result-count>{workCount}</span> {t.projects.index.resultLabel}</p>
      </div>

      <div class="project-filter-bar project-index-rail__filters" role="toolbar" aria-label={t.projects.pageTitle}>
        {filters.map((filter) => (
          <button
            type="button"
            data-project-filter={filter.id}
            data-project-description={filter.description}
            data-project-label={filter.label}
            data-project-count={filter.count}
            aria-controls="project-index-list"
            aria-pressed={filter.id === 'all' ? 'true' : 'false'}
          >
            <span>{filter.label}</span><b>{String(filter.count).padStart(2, '0')}</b>
          </button>
        ))}
      </div>

      <p class="project-index-rail__description" data-project-rail-description>{filters[0].description}</p>

      <figure class="project-index-rail__preview">
        <figcaption class="panel-label">{t.projects.index.categoryPreview}</figcaption>
        {filters.map((filter) => (
          <img
            src={filter.preview.cover.src}
            alt={filter.preview.cover.alt[lang]}
            data-project-rail-preview={filter.id}
            hidden={filter.id !== 'all'}
            loading={filter.id === 'all' ? 'eager' : 'lazy'}
            decoding="async"
          />
        ))}
      </figure>
    </aside>

    <div class="project-index-panel">
      <p class="sr-only" data-project-filter-status aria-live="polite" data-status-prefix={t.projects.index.statusPrefix} data-result-label={t.projects.index.resultLabel}>
        {t.projects.index.statusPrefix} {filters[0].label}: {workCount} {t.projects.index.resultLabel}.
      </p>
      <div id="project-index-list" class="project-index" data-project-index aria-busy="false">
      {projects.map((project) => <ProjectIndexRow project={project} lang={lang} labels={t.projects.labels} />)}
      </div>
    </div>
  </section>
</div>

<script>
  const bindProjectFilters = () => {
    document.querySelectorAll<HTMLElement>('[data-project-filtering]').forEach((root) => {
      if (root.dataset.projectFiltersBound === 'true') return;
      root.dataset.projectFiltersBound = 'true';

      const buttons = root.querySelectorAll<HTMLButtonElement>('[data-project-filter]');
      const rows = root.querySelectorAll<HTMLElement>('[data-project-categories]');
      const index = root.querySelector<HTMLElement>('[data-project-index]');
      const currentFilter = root.querySelector<HTMLElement>('[data-project-current-filter]');
      const resultCount = root.querySelector<HTMLElement>('[data-project-result-count]');
      const description = root.querySelector<HTMLElement>('[data-project-rail-description]');
      const status = root.querySelector<HTMLElement>('[data-project-filter-status]');
      const previews = root.querySelectorAll<HTMLImageElement>('[data-project-rail-preview]');
      let filterTimer: number | undefined;

      const updateRows = (selected: string) => {
        if (filterTimer !== undefined) window.clearTimeout(filterTimer);
        const reduceMotion = document.documentElement.dataset.motion === 'reduced';
        const visibleBefore = new Map<HTMLElement, DOMRect>();
        rows.forEach((row) => {
          if (!row.hidden) visibleBefore.set(row, row.getBoundingClientRect());
        });

        const isVisible = (row: HTMLElement) => selected === 'all' || (row.dataset.projectCategories ?? '').split(' ').includes(selected);
        rows.forEach((row) => {
          if (!isVisible(row) && !row.hidden) row.classList.add('is-filtering-out');
        });
        index?.setAttribute('aria-busy', 'true');

        filterTimer = window.setTimeout(() => {
          rows.forEach((row) => {
            row.hidden = !isVisible(row);
            row.classList.remove('is-filtering-out');
          });

          requestAnimationFrame(() => {
            if (!reduceMotion) {
              rows.forEach((row) => {
                if (row.hidden) return;
                const before = visibleBefore.get(row);
                const after = row.getBoundingClientRect();
                if (!before) {
                  row.animate([{ opacity: 0, transform: 'translateY(0.45rem)' }, { opacity: 1, transform: 'translateY(0)' }], { duration: 180, easing: 'ease-out' });
                  return;
                }
                const deltaY = before.top - after.top;
                if (Math.abs(deltaY) > 1) {
                  row.animate([{ transform: `translateY(${deltaY}px)` }, { transform: 'translateY(0)' }], { duration: 180, easing: 'ease-out' });
                }
              });
            }
            index?.setAttribute('aria-busy', 'false');
            filterTimer = undefined;
          });
        }, reduceMotion ? 0 : 110);
      };

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const selected = button.dataset.projectFilter ?? 'all';

          buttons.forEach((candidate) => {
            candidate.setAttribute('aria-pressed', String(candidate === button));
          });

          const count = Number(button.dataset.projectCount ?? rows.length);
          currentFilter && (currentFilter.textContent = button.dataset.projectLabel ?? '');
          resultCount && (resultCount.textContent = String(count).padStart(2, '0'));
          description && (description.textContent = button.dataset.projectDescription ?? '');
          previews.forEach((preview) => {
            preview.hidden = preview.dataset.projectRailPreview !== selected;
          });
          if (status) {
            const prefix = status.dataset.statusPrefix ?? '';
            const label = button.dataset.projectLabel ?? '';
            const resultLabel = status.dataset.resultLabel ?? '';
            status.textContent = `${prefix} ${label}: ${String(count).padStart(2, '0')} ${resultLabel}.`;
          }

          updateRows(selected);
          document.dispatchEvent(new CustomEvent('spatial:project-filter', { detail: { category: selected } }));
        });
      });
    });
  };

  document.addEventListener('astro:page-load', bindProjectFilters);
  bindProjectFilters();
</script>
