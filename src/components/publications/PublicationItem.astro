---
import type { PublicationRecord } from '../../data/publications';
import { getProject, type LinkValue } from '../../data/projects';
import type { Lang } from '../../i18n';

interface Props {
  publication: PublicationRecord;
  lang: Lang;
  labels: {
    pdf: string;
    code: string;
    project: string;
  };
}

const { publication, lang, labels } = Astro.props as Props;
const project = publication.projectId ? getProject(publication.projectId) : undefined;
const resolveLink = (value: LinkValue | undefined) => (typeof value === 'string' ? value : value?.[lang] ?? '');
const title = publication.title?.[lang] ?? project?.title[lang] ?? '';
const authors = publication.authors?.[lang];
const venue = publication.venue?.[lang] ?? (project?.course ? (typeof project.course === 'string' ? project.course : project.course[lang]) : '');
const year = publication.year ?? project?.year ?? '';
const links = [
  { label: labels.pdf, href: resolveLink(project?.links.report) },
  { label: labels.code, href: resolveLink(project?.links.code) },
  { label: labels.project, href: resolveLink(project?.links.details) },
].filter((link) => Boolean(link.href));
const isExternal = (href: string) => href.startsWith('http');
const requiresDocumentNavigation = (href: string) => isExternal(href) || /\.(?:pdf|pptx)(?:$|[?#])/i.test(href);
---

<article class="publication-item" data-publication-kind={publication.kind}>
  <span class="publication-item__archive-mark" aria-hidden="true"><i></i><i></i><i></i></span>
  <div class="publication-year">{year}</div>
  <div class="publication-copy">
    <p class="panel-label">{publication.type[lang]} · {publication.status[lang]}</p>
    <h3>{title}</h3>
    {authors && <p class="publication-meta">{authors}</p>}
    {venue && <p class="publication-meta"><em>{venue}</em></p>}
    {
      links.length > 0 && (
        <div class="inline-links" aria-label={`${title} publication links`}>
          {links.map(({ label, href }) => (
            <a
              href={href}
              target={isExternal(href) ? '_blank' : undefined}
              rel={isExternal(href) ? 'noreferrer' : undefined}
              data-astro-reload={requiresDocumentNavigation(href) ? '' : undefined}
            >
              {label}
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>
