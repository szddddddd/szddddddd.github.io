---
import type { Lang } from '../../i18n';
import { getCopy } from '../../i18n';
import { profile } from '../../data/profile';
import Section from '../ui/Section.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props as Props;
const t = getCopy(lang);
const display = profile.display[lang];
const identityRows = [
  { label: t.hero.identityLabels.role, value: display.role },
  { label: t.hero.identityLabels.university, value: display.university },
  { label: t.hero.identityLabels.lab, value: profile.lab },
  { label: t.hero.identityLabels.major, value: display.major },
];
---

<div class="page-stack about-page">
  <section class="page-hero about-page-hero" aria-labelledby="about-page-title">
    <div class="about-identity-space">
      <div class="detail-hero-copy">
        <p class="eyebrow" transition:name="page-index">01 / {t.nav.about}</p>
        <h1 id="about-page-title" transition:name="page-main-title">{t.about.statement}</h1>
        <p>{t.about.intro}</p>
      </div>

      <aside class="about-identity-matrix" aria-label={t.about.profileTitle}>
        <div class="about-coordinate-field" aria-hidden="true">
          <i></i><i></i><i></i><b></b><b></b><b></b>
        </div>
        <dl class="fact-list about-fact-grid">
          {identityRows.map((item) => (
            <div>
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))}
        </dl>
      </aside>
    </div>
  </section>

  <Section id="research-focus" eyebrow={t.about.interestsTitle} title={t.about.focusTitle} intro={t.about.focusIntro}>
    <div class="about-focus-map">
      <div class="about-focus-map__signal" aria-hidden="true"><i></i><i></i><i></i><b></b><b></b><b></b></div>
      <div class="detail-two-column about-focus-map__lists">
        <ul class="interest-list" aria-label={t.about.interestsTitle}>
          {profile.researchInterests.map((interest) => <li>{interest}</li>)}
        </ul>
        <ul class="interest-list">
          {t.about.focusItems.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </Section>

  <Section id="contact" eyebrow={t.about.contactTitle} title={t.about.contactTitle} intro={t.about.contactIntro}>
    <div class="contact-grid about-contact-grid">
      <article class="about-contact-item">
        <p class="panel-label">{t.about.contactLabels.email}</p>
        <a class="contact-link" href={`mailto:${profile.email}`}>{profile.email}</a>
      </article>
      <article class="about-contact-item">
        <p class="panel-label">{t.about.contactLabels.github}</p>
        <a class="contact-link" href={profile.githubUrl} target="_blank" rel="noreferrer" data-astro-reload>{profile.githubUrl}</a>
      </article>
      <article class="about-contact-item">
        <p class="panel-label">{t.about.contactLabels.cv}</p>
        {
          profile.cv.url ? (
            <a class="contact-link" href={profile.cv.url} data-astro-reload>{t.hero.cvAction}</a>
          ) : (
            <p class="contact-link muted">{t.common.comingSoon}</p>
          )
        }
      </article>
    </div>
  </Section>
</div>
