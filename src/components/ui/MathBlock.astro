---
import katex from 'katex';
import 'katex/dist/katex.min.css';

interface Props {
  tex: string;
  display?: boolean;
  label?: string;
}

const { tex, display = true, label } = Astro.props as Props;
const html = katex.renderToString(tex, {
  displayMode: display,
  throwOnError: false,
  strict: false,
});
---

<figure class="math-figure">
  <div class:list={['math-block', display && 'math-display']} set:html={html} />
  {label && <figcaption>{label}</figcaption>}
</figure>
