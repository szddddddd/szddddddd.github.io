---
import { ClientRouter } from 'astro:transitions';
import AppShell from '../components/layout/AppShell.astro';
import { getRouteForPage } from '../config/routes';
import { site } from '../config/site';
import { profile } from '../data/profile';
import { getCopy, getPath, type Lang, type PageKey } from '../i18n';
import '../styles/global.css';
import '../styles/navigation.css';
import '../styles/pages/atlas.css';

interface Props {
  lang: Lang;
  page: PageKey;
  title?: string;
  description?: string;
}

const { lang, page, title, description } = Astro.props as Props;
const t = getCopy(lang);
const route = getRouteForPage(page);
const canonicalPage = page === 'coursework' ? 'projects' : page;
const pageTitle = title ?? `${route.label[lang]} | ${profile.display[lang].name}`;
const pageDescription = description ?? route.description[lang];
const siteUrl = Astro.site ?? new URL(site.url);
const canonical = new URL(getPath(lang, canonicalPage), siteUrl).toString();
const alternateEn = new URL(getPath('en', canonicalPage), siteUrl).toString();
const alternateZh = new URL(getPath('zh', canonicalPage), siteUrl).toString();
---

<!doctype html>
<html lang={t.htmlLang} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="theme-color" content="#05070b" id="theme-color-meta" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={alternateEn} />
    <link rel="alternate" hreflang="zh-CN" href={alternateZh} />
    <link rel="alternate" hreflang="x-default" href={alternateEn} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={t.meta.siteTitle} />
    <meta name="twitter:card" content="summary" />
    <meta name="author" content={profile.nameEn} />
    <title>{pageTitle}</title>
    <ClientRouter />
    <script is:inline>
      (() => {
        const darkThemeColor = '#05070b';
        const lightThemeColor = '#f6f7f4';
        try {
          const storedTheme = localStorage.getItem('theme');
          const theme = storedTheme === 'light' ? 'light' : 'dark';
          const motion = localStorage.getItem('motion') !== 'off' && !window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          document.documentElement.dataset.theme = theme;
          document.documentElement.dataset.motion = motion ? 'enabled' : 'reduced';
          document.documentElement.style.colorScheme = theme;
          document.querySelector('meta[name="theme-color"]')?.setAttribute('content', theme === 'light' ? lightThemeColor : darkThemeColor);
        } catch {
          document.documentElement.dataset.theme = 'dark';
          document.documentElement.dataset.motion = 'enabled';
        }
      })();
    </script>
  </head>
  <body data-page-key={page} data-spatial-route={route.id} style={`--page-accent:${route.accent};`}>
    <a class="skip-link" href="#main-content">{t.common.skipToContent}</a>
    <AppShell lang={lang} page={page}>
      <slot />
    </AppShell>
    <script>
      import { bootSpatialUI } from '../spatial/core/bootstrap';

      const boot = () => void bootSpatialUI();
      document.addEventListener('astro:page-load', boot);
      boot();
    </script>
  </body>
</html>
