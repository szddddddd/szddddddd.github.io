---
import type { Lang, PageKey } from '../../i18n';
import { getCopy, getPath } from '../../i18n';
import { profile } from '../../data/profile';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AboutPage from '../pages/AboutPage.astro';
import HomePage from '../pages/HomePage.astro';
import HumanitiesPage from '../pages/HumanitiesPage.astro';
import NotesPage from '../pages/NotesPage.astro';
import ProjectsPage from '../pages/ProjectsPage.astro';
import PublicationsPage from '../pages/PublicationsPage.astro';
import Section from '../ui/Section.astro';

interface Props {
  lang: Lang;
  page: PageKey;
}

const { lang, page } = Astro.props as Props;
const t = getCopy(lang);
const display = profile.display[lang];

const titles: Record<PageKey, string> = {
  home: t.meta.siteTitle,
  about: `${t.nav.about} — ${display.name}`,
  projects: `${t.nav.projects} — ${display.name}`,
  projectSi140a: t.si140a.metaTitle,
  projectBme1312: t.bme1312.metaTitle,
  projectBme1312Proj2: t.bme1312Proj2.metaTitle,
  projectCs182: t.cs182.metaTitle,
  projectSi100b: t.si100b.metaTitle,
  projectArts1308: t.arts1308.metaTitle,
  publications: t.publications.pageTitle,
  humanities: t.humanities.pageTitle,
  coursework: `${t.nav.coursework} — ${display.name}`,
  notes: t.notes.pageTitle,
};

const descriptions: Record<PageKey, string> = {
  home: t.meta.description,
  about: t.about.intro,
  projects: t.projects.fullIntro,
  projectSi140a: t.si140a.metaDescription,
  projectBme1312: t.bme1312.metaDescription,
  projectBme1312Proj2: t.bme1312Proj2.metaDescription,
  projectCs182: t.cs182.metaDescription,
  projectSi100b: t.si100b.metaDescription,
  projectArts1308: t.arts1308.metaDescription,
  publications: t.publications.intro,
  humanities: t.humanities.intro,
  coursework: t.coursework.intro,
  notes: t.notes.intro,
};
---

<BaseLayout lang={lang} page={page} title={titles[page]} description={descriptions[page]}>
  {page === 'home' && <HomePage lang={lang} />}
  {page === 'about' && <AboutPage lang={lang} />}
  {page === 'projects' && <ProjectsPage lang={lang} />}
  {page === 'publications' && <PublicationsPage lang={lang} />}
  {page === 'humanities' && <HumanitiesPage lang={lang} />}
  {page === 'notes' && <NotesPage lang={lang} />}

  {
    page === 'coursework' && (
      <div class="page-stack">
        <section class="page-hero page-hero-compact">
          <p class="eyebrow">02 / {t.nav.projects}</p>
          <h1>{t.coursework.pageTitle}</h1>
          <p>{t.coursework.mergedIntro}</p>
        </section>

        <Section>
          <div class="coursework-merged-notice">
            <p class="panel-label">{t.coursework.mergedTitle}</p>
            <p>{t.coursework.mergedIntro}</p>
            <a class="text-link" href={getPath(lang, 'projects')}>{t.coursework.viewProjects}</a>
          </div>
        </Section>
      </div>
    )
  }
</BaseLayout>
