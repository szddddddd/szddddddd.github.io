---
import ShaderPortal from './ShaderPortal.astro';
import { profile } from '../data/profile';
import { getCopy, getPath, type Lang } from '../i18n';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/spatial-explore.css';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props as Props;
const t = getCopy(lang);
const explore = t.explore;
const links = [
  { label: explore.links.projects, href: getPath(lang, 'projects'), note: 'Research / reconstruction' },
  { label: explore.links.shaderArt, href: getPath(lang, 'projectArts1308'), note: 'GLSL / pixel studies' },
  { label: explore.links.github, href: profile.githubUrl, note: 'Code and experiments', external: true },
  { label: explore.links.contact, href: `${getPath(lang, 'about')}#contact`, note: 'Research discussion' },
];
---

<BaseLayout lang={lang} page="explore" title={explore.metaTitle} description={explore.metaDescription}>
  <div class="spatial-explore-page page-stack">
    <div class="spatial-explore-topbar">
      <a class="button button-secondary" href={getPath(lang, 'home')}>← {explore.backHome}</a>
    </div>

    <section class="page-hero spatial-explore-hero" aria-labelledby="spatial-worlds-title">
      <p class="eyebrow">{explore.eyebrow}</p>
      <h1 id="spatial-worlds-title">{explore.pageTitle}</h1>
      <p>{explore.pageIntro}</p>
    </section>

    <ShaderPortal
      variant="large"
      class="spatial-explore-portal"
      title={explore.pageTitle}
      subtitle={explore.cardSubtitle}
      kicker="Raymarching SDF / toon outline / spatial grid"
      actionLabel={explore.links.projects}
      actionHref={getPath(lang, 'projects')}
    />

    <section class="spatial-explore-content" aria-label={explore.linksTitle}>
      <article class="panel spatial-explore-intro">
        <p class="panel-label">{explore.pageTitle}</p>
        <p>{explore.body}</p>
      </article>

      <nav class="spatial-explore-links" aria-label={explore.linksTitle}>
        {links.map((item) => (
          <a class="spatial-explore-link" href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noreferrer' : undefined}>
            <span>{item.label}</span>
            <small>{item.note}</small>
          </a>
        ))}
      </nav>
    </section>
  </div>
</BaseLayout>
