---
import type { Publication } from '../data/profile';

interface Props {
  publication: Publication;
  labels: {
    paper: string;
    code: string;
    bibtex: string;
    doi: string;
  };
  comingSoon: string;
}

const { publication, labels, comingSoon } = Astro.props as Props;
const links = [
  { label: labels.paper, value: publication.paperUrl },
  { label: labels.code, value: publication.codeUrl },
  { label: labels.bibtex, value: publication.bibtex },
  { label: labels.doi, value: publication.doi },
];
const isUrl = (value: string) => value.startsWith('http') || value.startsWith('/') || value.startsWith('mailto:');
---

<article class="publication-item">
  <div class="publication-year">{publication.year}</div>
  <div class="publication-copy">
    <h3>{publication.title}</h3>
    <p class="publication-meta">{publication.authors}. <em>{publication.venue}</em>.</p>
    <div class="inline-links" aria-label={`${publication.title} publication links`}>
      {
        links.map(({ label, value }) =>
          value && isUrl(value) ? (
            <a href={value} target={value.startsWith('http') ? '_blank' : undefined} rel={value.startsWith('http') ? 'noreferrer' : undefined}>
              {label}
            </a>
          ) : (
            <span class="disabled-link">{label}: {comingSoon}</span>
          )
        )
      }
    </div>
  </div>
</article>
