---
import LanguageToggle from './LanguageToggle.astro';
import MotionToggle from '../ui/MotionToggle.astro';
import ThemeToggle from '../ui/ThemeToggle.astro';
import { profile } from '../../data/profile';
import { getCopy, getPath, primaryNavPageKeys, type Lang, type PageKey, type PrimaryNavPageKey } from '../../i18n';

interface Props {
  lang: Lang;
  page: PageKey;
}

const { lang, page } = Astro.props as Props;
const t = getCopy(lang);
const display = profile.display[lang];
const navItems = primaryNavPageKeys.map((pageKey) => ({ page: pageKey, href: getPath(lang, pageKey), label: t.nav[pageKey] }));
const activePage: PrimaryNavPageKey = primaryNavPageKeys.includes(page as PrimaryNavPageKey)
  ? (page as PrimaryNavPageKey)
  : page === 'coursework' || page.startsWith('project')
    ? 'projects'
    : 'home';
---

<header class="navbar rsui-command-center" data-rsui-navigation data-rsui-page={activePage}>
  <a class="brand rsui-command-center__brand" data-rsui-magnetic href={getPath(lang, 'home')} aria-label={`${display.name} home`}>
    <span class="brand-mark">SZD</span>
    <span class="brand-copy">
      <strong>{display.name}</strong>
      <small>{display.role} · {profile.lab}</small>
    </span>
  </a>

  <div class="nav-cluster rsui-command-center__cluster">
    <nav class="nav-links rsui-command-center__routes" aria-label="Primary navigation">
      {navItems.map((item, index) => (
        <a
          href={item.href}
          data-rsui-route
          data-rsui-magnetic
          data-rsui-route-index={String(index + 1).padStart(2, '0')}
          aria-current={activePage === item.page ? 'page' : undefined}
        >
          <span>{item.label}</span>
        </a>
      ))}
    </nav>
    <div class="nav-actions rsui-command-center__actions">
      <LanguageToggle lang={lang} page={page} />
      <ThemeToggle lang={lang} />
      <MotionToggle lang={lang} />
    </div>
  </div>
</header>
