---
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PublicationItem from '../components/PublicationItem.astro';
import Section from '../components/Section.astro';
import { profile } from '../data/profile';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title={`${profile.name} — Academic Portfolio`} description={profile.bio}>
  <Hero />

  <Section
    id="about"
    eyebrow="About"
    title="A compact academic identity system"
    intro="This page is intentionally placeholder-first: structure, hierarchy, and visual language are ready for real academic content."
  >
    <div class="about-grid">
      <article class="panel panel-large">
        <p class="panel-label">Bio</p>
        <p class="large-copy">{profile.bio}</p>
      </article>
      <article class="panel">
        <p class="panel-label">Research interests</p>
        <ul class="interest-list">
          {profile.researchInterests.map((interest) => <li>{interest}</li>)}
        </ul>
      </article>
      <article class="panel">
        <p class="panel-label">Education / Affiliation</p>
        <ul class="interest-list">
          {profile.education.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </Section>

  <Section
    id="research"
    eyebrow="Research / Projects"
    title="Projects as research artifacts"
    intro="Cards are ready for papers, code, demos, datasets, or visual studies."
  >
    <div class="project-grid">
      {profile.projects.map((project) => <ProjectCard project={project} />)}
    </div>
    <a class="text-link" href="/projects">Open full project index →</a>
  </Section>

  <Section
    id="publications"
    eyebrow="Publications"
    title="Scholarly output"
    intro="Publication entries support venue, year, BibTeX, DOI, and PDF links."
  >
    <div class="publication-list">
      {profile.publications.map((publication) => <PublicationItem publication={publication} />)}
    </div>
    <a class="text-link" href="/publications">Open publication list →</a>
  </Section>

  <Section
    id="notes"
    eyebrow="Notes / Blog"
    title="A future place for short-form thinking"
    intro={profile.notes.description}
  >
    <div class="note-placeholder">
      <span>Coming soon</span>
      <p>No posts have been added yet.</p>
    </div>
  </Section>
</BaseLayout>
