---
interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  intro?: string;
  className?: string;
}

const { id, eyebrow, title, intro, className = '' } = Astro.props;
---

<section id={id} class={`section ${className}`}>
  <div class="section-heading">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h2>{title}</h2>
    {intro && <p>{intro}</p>}
  </div>
  <div class="section-body">
    <slot />
  </div>
</section>
