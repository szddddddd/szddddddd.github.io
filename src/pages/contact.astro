---
import Section from '../components/Section.astro';
import { profile } from '../data/profile';
import BaseLayout from '../layouts/BaseLayout.astro';

const cvIsUrl = profile.links.cv.startsWith('http') || profile.links.cv.startsWith('/');
---

<BaseLayout title={`Contact — ${profile.name}`} description="Contact placeholders.">
  <section class="page-hero page-hero-compact">
    <p class="eyebrow">Contact</p>
    <h1>Contact and links</h1>
    <p>Only placeholder contact fields are shown. Replace them when real information is ready.</p>
  </section>

  <Section title="Connect" intro="Edit src/data/profile.ts to update email, GitHub, CV, and future links.">
    <div class="contact-grid">
      <article class="panel">
        <p class="panel-label">Email</p>
        <a class="contact-link" href={`mailto:${profile.links.email}`}>{profile.links.email}</a>
      </article>
      <article class="panel">
        <p class="panel-label">GitHub</p>
        <a class="contact-link" href={profile.links.github} target="_blank" rel="noreferrer">{profile.links.github}</a>
      </article>
      <article class="panel">
        <p class="panel-label">CV</p>
        {
          cvIsUrl ? (
            <a class="contact-link" href={profile.links.cv}>{profile.links.cv}</a>
          ) : (
            <p class="contact-link muted">{profile.links.cv}</p>
          )
        }
      </article>
    </div>
  </Section>
</BaseLayout>
