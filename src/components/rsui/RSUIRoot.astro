---
import '../../styles/rsui/engine.css';
---

<div class="rsui-root" data-rsui-root>
  <div class="rsui-engine-host" data-rsui-host aria-hidden="true"></div>

  <div class="rsui-cursor" data-rsui-cursor aria-hidden="true">
    <span class="rsui-cursor__core"></span>
    <span class="rsui-cursor__ring"></span>
  </div>

  <aside
    class="rsui-project-inspector"
    data-rsui-project-inspector
    aria-labelledby="rsui-project-inspector-title"
    aria-describedby="rsui-project-inspector-body"
    hidden
  >
    <p class="rsui-project-inspector__eyebrow" data-rsui-project-inspector-eyebrow>Research node</p>
    <h2 id="rsui-project-inspector-title" data-rsui-project-inspector-title data-rsui-project-title>Project preview</h2>
    <div id="rsui-project-inspector-body" class="rsui-project-inspector__body" data-rsui-project-inspector-body data-rsui-project-body></div>
    <nav class="rsui-project-inspector__links" data-rsui-project-inspector-links data-rsui-project-links aria-label="Project links"></nav>
  </aside>

  <p class="rsui-route-status" data-rsui-route-status role="status" aria-live="polite" aria-atomic="true"></p>
</div>
