---
import MathBlock from '../ui/MathBlock.astro';
import Section from '../ui/Section.astro';
import { profile } from '../../data/profile';
import { cs182CourseProject } from '../../data/projects';
import { getCopy, type Lang } from '../../i18n';
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props as Props;
const t = getCopy(lang);
const copy = t.cs182;
const project = cs182CourseProject;
const typeLabel = project.type?.[lang] ?? t.common.courseProject;
const visualItems = copy.gallery;
const details = [
  { label: copy.labels.course, value: project.course ?? 'CS182: Introduction to Machine Learning' },
  { label: copy.labels.type, value: typeLabel },
  { label: copy.labels.year, value: project.year },
  { label: copy.labels.authors, value: copy.authors.join(' · ') },
];
const resolveLink = (value: string | { en: string; zh: string } | undefined) => {
  if (!value) return '';
  return typeof value === 'string' ? value : value[lang];
};
const reportHref = resolveLink(project.links.report);
const codeHref = resolveLink(project.links.code);
const authorSentence =
  lang === 'zh'
    ? `该项目由 ${copy.authors[0]}、${copy.authors[1]} 和 ${copy.authors[2]} 作为 CS182 课程项目完成。`
    : `This project was completed as a CS182 course project by ${copy.authors[0]}, ${copy.authors[1]}, and ${copy.authors[2]}.`;
const compoundLoss = copy.lossCards[2];
---

<BaseLayout lang={lang} page="projectCs182" title={copy.metaTitle} description={copy.metaDescription}>
  <article class="project-detail cs182-detail">
    <header class="project-detail-hero">
      <div class="detail-hero-copy reveal-block">
        <p class="eyebrow" transition:name="page-index">{copy.hero.eyebrow}</p>
        <h1 class="project-detail-title" transition:name="project-title-cs182">{copy.hero.title}</h1>
        <p class="detail-subtitle wide-subtitle">{copy.hero.subtitle}</p>
        <p class="detail-affiliation">{copy.hero.affiliation}</p>
        <ul class="tag-list expanded-tags detail-tags" aria-label="Project metadata tags">
          {copy.metadata.map((item) => <li>{item}</li>)}
        </ul>
        <div class="hero-actions detail-actions">
          <a class="button button-secondary" href={`mailto:${profile.email}`}>{t.hero.emailAction}</a>
          {
            reportHref ? (
              <a class="button button-secondary" href={reportHref} data-astro-reload>{t.projects.labels.report}</a>
            ) : (
              <span class="button button-disabled" aria-disabled="true">{t.projects.labels.report}: {t.common.comingSoon}</span>
            )
          }
          {
            codeHref ? (
              <a class="button button-secondary" href={codeHref} data-astro-reload>{t.projects.labels.code}</a>
            ) : (
              <span class="button button-disabled" aria-disabled="true">{t.projects.labels.code}: {t.common.comingSoon}</span>
            )
          }
        </div>
      </div>
      <figure class="detail-hero-figure reveal-block">
        <img src={project.cover.src} alt={project.cover.alt[lang]} loading="eager" transition:name="project-cover-cs182" />
        <figcaption>{project.title[lang]}</figcaption>
      </figure>
    </header>

    <section class="metadata-grid" aria-label="Project metadata">
      {details.map((item) => (
        <article>
          <span>{item.label}</span>
          <strong>{item.value}</strong>
        </article>
      ))}
    </section>

    <Section id="overview" eyebrow="CS182" title={copy.sections.overview} intro={copy.overview}>
      <div class="detail-two-column">
        <div class="panel project-summary-panel">
          <p class="panel-label">{copy.labels.summary}</p>
          <ul class="interest-list">
            {copy.overviewBullets.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="panel narrative-panel">
          <p>{authorSentence}</p>
        </div>
      </div>
    </Section>

    <Section id="method" title={copy.sections.method} intro={copy.methodIntro}>
      <div class="method-grid">
        {copy.methodCards.map((card) => (
          <article class="method-card">
            <p class="panel-label">{copy.labels.method}</p>
            <h3>{card.title}</h3>
            <ul class="interest-list">
              {card.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>

      <div class="method-detail-grid">
        <article class="panel formula-card method-technical-panel">
          <p class="panel-label">{copy.sections.loss}</p>
          <MathBlock tex={compoundLoss.tex} />
          <p>{copy.lossIntro}</p>
          <ul class="interest-list compact-interest-list">
            {copy.lossHighlights.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="panel method-technical-panel">
          <p class="panel-label">{copy.sections.pruning}</p>
          <p>{copy.pruningIntro}</p>
          <ul class="interest-list compact-interest-list">
            {copy.pruningCards.map((card) => (
              <li><strong>{card.title}:</strong> {card.items[card.items.length - 1]}</li>
            ))}
          </ul>
        </article>
      </div>
    </Section>

    <Section id="experiments-results" title={copy.sections.experiments} intro={copy.experimentsIntro}>
      <div class="metric-table" role="table" aria-label="CS182 MOF3R quantitative comparison">
        <div class="metric-row metric-row-3 metric-head" role="row">
          {copy.resultColumns.map((column) => <span role="columnheader">{column}</span>)}
        </div>
        {copy.resultRows.map((row) => (
          <div class="metric-row metric-row-3" role="row">
            {row.map((cell, index) => <span role="cell" class:list={{ 'metric-model': index === 0 }}>{cell}</span>)}
          </div>
        ))}
      </div>
      <div class="metric-cards metric-cards-three" aria-label={copy.labels.metricChanges}>
        <article><span>PSNR</span><strong>19.07 → 23.56</strong></article>
        <article><span>SSIM</span><strong>0.592 → 0.935</strong></article>
        <article><span>LPIPS</span><strong>0.629 → 0.120</strong></article>
      </div>
      <div class="panel highlight-panel">
        <p class="panel-label">{copy.labels.summary}</p>
        <ul class="highlight-list">
          {copy.resultHighlights.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </Section>

    <Section id="visual-results" title={copy.sections.gallery} intro={copy.galleryIntro}>
      <div class="gallery-grid cs182-visual-grid">
        {visualItems.map((item) => (
          <figure class="detail-figure">
            <img src={item.src} alt={item.alt} loading="lazy" />
            <figcaption>{item.caption}</figcaption>
          </figure>
        ))}
      </div>
    </Section>
  </article>
</BaseLayout>
