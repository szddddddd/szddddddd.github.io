---
import type { Lang } from '../../i18n';
import { primaryRoutes } from '../../i18n';
import type { RouteDefinition } from '../../config/routes';
import { profile } from '../../data/profile';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props as Props;
const display = profile.display[lang];
const nodes = (primaryRoutes as readonly RouteDefinition[]).filter((route) => route.id !== 'home');
const interests = lang === 'zh'
  ? '三维视觉 / 三维重建 / 神经渲染 / 高斯泼溅 / 生成式世界模型'
  : '3D Vision / 3D Reconstruction / Neural Rendering / Gaussian Splatting / Generative World Models';
const statement = lang === 'zh'
  ? '我关注机器如何感知、重建并生成三维世界。'
  : 'I explore how machines perceive, reconstruct, and imagine three-dimensional worlds.';
---

<section class="atlas-home" aria-labelledby="home-title">
  <div class="atlas-home__intro">
    <p class="atlas-home__eyebrow" transition:name="page-index">00 / {lang === 'zh' ? '空间研究图谱' : 'SPATIAL RESEARCH ATLAS'}</p>
    <h1 id="home-title" transition:name="page-main-title">{display.name}</h1>
    <p class="atlas-home__statement">{statement}</p>
    <p class="atlas-home__identity">{display.role} / {display.university} / {profile.lab} / {display.major}</p>
    <p class="atlas-home__interests">{interests}</p>
  </div>

  <nav class="atlas-home__entries" aria-label={lang === 'zh' ? '研究索引' : 'Research index'}>
    {nodes.map((route) => (
      <a
        class:list={['atlas-home__entry', `atlas-home__entry--${route.id}`]}
        href={route.path[lang]}
        data-spatial-preview={route.id}
        data-home-route={route.id}
        style={`--node-accent:${route.accent};`}
        transition:name={`home-node-${route.id}`}
      >
        <span class="atlas-home__entry-visual" aria-hidden="true">
          {
            route.id === 'about' && (
              <span class="atlas-home__identity-object">
                <i></i><i></i><i></i><b></b><b></b><b></b>
              </span>
            )
          }
          {
            route.id === 'projects' && (
              <span class="atlas-home__project-object"><i></i><b></b></span>
            )
          }
          {
            route.id === 'publications' && (
              <span class="atlas-home__archive-object">
                <i></i><i></i><i></i><b></b><b></b><b></b>
              </span>
            )
          }
          {
            route.id === 'notes' && (
              <span class="atlas-home__network-object">
                <i></i><i></i><i></i><i></i><b></b><b></b><b></b>
              </span>
            )
          }
          {
            route.id === 'humanities' && (
              <span class="atlas-home__humanities-object"><i></i><i></i><i></i><b></b></span>
            )
          }
        </span>
        <span class="atlas-home__entry-copy">
          <span class="atlas-home__node-index">{route.index}</span>
          <span class="atlas-home__node-title">{route.label[lang]}</span>
          <span class="atlas-home__node-description">{route.description[lang]}</span>
        </span>
      </a>
    ))}
  </nav>
</section>

<script>
  const bindHomeRouteLocks = () => {
    document.querySelectorAll<HTMLElement>('[data-home-route]').forEach((entry) => {
      if (entry.dataset.homeRouteBound === 'true') return;
      entry.dataset.homeRouteBound = 'true';

      const lockRoute = () => {
        const route = entry.dataset.homeRoute;
        if (!route) return;
        entry.dataset.routeLocked = 'true';
        document.documentElement.dataset.spatialNavLock = route;
        document.dispatchEvent(new CustomEvent('spatial:nav-preview', { detail: { route } }));
      };

      entry.addEventListener('pointerdown', lockRoute);
      entry.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') lockRoute();
      });
    });
  };

  const clearHomeRouteLock = () => {
    delete document.documentElement.dataset.spatialNavLock;
  };

  document.addEventListener('astro:page-load', () => {
    bindHomeRouteLocks();
    clearHomeRouteLock();
  });
  bindHomeRouteLocks();
</script>
