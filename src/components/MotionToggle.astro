---
import { getCopy, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props as Props;
const labels = getCopy(lang).common.motionToggle;
---

<button
  class="motion-toggle"
  type="button"
  data-motion-toggle
  data-on-label={labels.on}
  data-off-label={labels.off}
  data-on-aria={labels.switchOn}
  data-off-aria={labels.switchOff}
  aria-label={labels.switchOff}
  aria-pressed="true"
>
  <span class="motion-toggle-icon" aria-hidden="true">✦</span>
  <span class="motion-toggle-text" data-motion-toggle-text>{labels.on}</span>
</button>

<script is:inline>
  (() => {
    const storageKey = 'motion';
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    let transientPreference = null;

    const getStoredPreference = () => {
      if (transientPreference !== null) return transientPreference;
      try {
        return localStorage.getItem(storageKey) !== 'off';
      } catch {
        return true;
      }
    };

    const getMotionEnabled = () => getStoredPreference() && !reducedMotion.matches;

    const syncButtons = (enabled) => {
      document.querySelectorAll('[data-motion-toggle]').forEach((button) => {
        const text = button.querySelector('[data-motion-toggle-text]');
        const icon = button.querySelector('.motion-toggle-icon');
        if (text) text.textContent = enabled ? button.dataset.onLabel : button.dataset.offLabel;
        if (icon) icon.textContent = enabled ? '✦' : '•';
        button.dataset.motionState = enabled ? 'on' : 'off';
        button.setAttribute('aria-pressed', String(enabled));
        button.setAttribute('aria-label', enabled ? button.dataset.offAria : button.dataset.onAria);
      });
    };

    const applyMotion = (persist) => {
      if (persist !== undefined) {
        transientPreference = persist;
        try {
          localStorage.setItem(storageKey, persist ? 'on' : 'off');
        } catch {
          // Keep the in-page preference even when storage is unavailable.
        }
      }
      const enabled = getMotionEnabled();
      document.documentElement.dataset.motion = enabled ? 'enabled' : 'reduced';
      syncButtons(enabled);
      document.dispatchEvent(new CustomEvent('site:motionchange', { detail: { enabled } }));
    };

    const bindMotionToggles = () => {
      if (window.__motionToggleBound) {
        applyMotion();
        return;
      }

      window.__motionToggleBound = true;
      document.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target : null;
        const toggle = target?.closest('[data-motion-toggle]');
        if (!toggle) return;
        applyMotion(!getStoredPreference());
      });

      const handlePreferenceChange = () => applyMotion();
      if ('addEventListener' in reducedMotion) {
        reducedMotion.addEventListener('change', handlePreferenceChange);
      } else {
        reducedMotion.addListener(handlePreferenceChange);
      }

      applyMotion();
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bindMotionToggles, { once: true });
    } else {
      bindMotionToggles();
    }

    document.addEventListener('astro:page-load', () => applyMotion());
  })();
</script>
