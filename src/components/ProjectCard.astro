---
import type { Lang, Project } from '../data/profile';

interface Props {
  project: Project;
  lang: Lang;
  labels: {
    paper: string;
    code: string;
    demo: string;
  };
  comingSoon: string;
  placeholder: string;
}

const { project, lang, labels, comingSoon, placeholder } = Astro.props as Props;
const title = project.title[lang];
const description = project.description[lang];
const year = project.year === 'Coming soon' ? comingSoon : project.year;
const links = [
  { key: 'paper', label: labels.paper, value: project.links.paper },
  { key: 'code', label: labels.code, value: project.links.code },
  { key: 'demo', label: labels.demo, value: project.links.demo },
];
const isUrl = (value: string) => value.startsWith('http') || value.startsWith('/') || value.startsWith('mailto:');
---

<article class="project-card reveal-card">
  <div class="project-media" aria-hidden="true">
    {project.image ? <img src={project.image} alt="" loading="lazy" /> : <div class="project-field"><span></span><span></span><span></span></div>}
  </div>
  <div class="card-topline">
    <span>{year}</span>
    <span>{placeholder}</span>
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
  <ul class="tag-list" aria-label={`${title} tags`}>
    {project.tags.map((tag) => <li>{tag}</li>)}
  </ul>
  <div class="inline-links" aria-label={`${title} links`}>
    {
      links.map(({ label, value }) =>
        value && isUrl(value) ? (
          <a href={value} target={value.startsWith('http') ? '_blank' : undefined} rel={value.startsWith('http') ? 'noreferrer' : undefined}>
            {label}
          </a>
        ) : (
          <span class="disabled-link">{label}: {comingSoon}</span>
        )
      )
    }
  </div>
</article>
