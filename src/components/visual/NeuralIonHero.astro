---
import '../../styles/visual/neural-ion-field.css';

interface Props {
  label?: string;
}

const { label = 'Neural ion field' } = Astro.props as Props;
---

<div class="neural-ion-hero reveal-block" data-neural-ion-hero data-neural-ion-state="idle" aria-hidden="true">
  <div class="neural-ion-fallback" aria-hidden="true"></div>
  <canvas class="neural-ion-canvas" aria-hidden="true" role="presentation"></canvas>
  <div class="neural-ion-vignette" aria-hidden="true"></div>
  <span class="neural-ion-index">{label}</span>
</div>

<script>
  import '../../scripts/visual/neural-ion-field';
</script>
