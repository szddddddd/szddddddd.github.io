---
import { profile } from '../data/profile';
import type { Lang } from '../i18n';
import '../styles/world-shader-gate.css';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props as Props;
const copy = lang === 'zh'
  ? {
      kicker: 'World Labs inspired / spatial intelligence inspired',
      subtitle: 'Spatial Vision / Neural Worlds',
      enter: '点击进入',
      aria: '程序化空间世界入口，点击进入主页',
    }
  : {
      kicker: 'World Labs inspired / spatial intelligence inspired',
      subtitle: 'Spatial Vision / Neural Worlds',
      enter: 'Click to enter',
      aria: 'Procedural spatial world entrance. Click to enter the homepage.',
    };
---

<section
  class="world-shader-gate"
  data-world-shader-gate
  data-world-shader-state="pending"
  role="dialog"
  aria-modal="true"
  aria-labelledby="world-gate-title"
  aria-describedby="world-gate-subtitle"
  aria-label={copy.aria}
>
  <div class="world-gate-fallback" aria-hidden="true"></div>
  <canvas class="world-gate-canvas" data-world-shader-canvas aria-hidden="true" role="presentation"></canvas>
  <div class="world-gate-grain" aria-hidden="true"></div>
  <div class="world-gate-vignette" aria-hidden="true"></div>

  <div class="world-gate-copy">
    <p class="world-gate-kicker">{copy.kicker}</p>
    <h2 id="world-gate-title">{profile.nameEn}</h2>
    <p id="world-gate-subtitle">{copy.subtitle}</p>
    <button class="world-gate-enter" type="button" data-world-gate-enter>
      <span>{copy.enter}</span>
    </button>
  </div>
</section>

<script>
  import '../scripts/world-shader-gate';
</script>
