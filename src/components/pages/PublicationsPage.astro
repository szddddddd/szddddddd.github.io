---
import type { Lang } from '../../i18n';
import { getCopy } from '../../i18n';
import { peerReviewed, technicalReports } from '../../data/publications';
import PublicationItem from '../publications/PublicationItem.astro';
import Section from '../ui/Section.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props as Props;
const t = getCopy(lang);
const peerReviewedCount = String(peerReviewed.length).padStart(2, '0');
const technicalReportCount = String(technicalReports.length).padStart(2, '0');
---

<div class="page-stack publications-page">
  <section class="page-hero page-hero-compact" aria-labelledby="publications-page-title">
    <p class="eyebrow" transition:name="page-index">03 / {t.nav.publications}</p>
    <h1 id="publications-page-title" transition:name="page-main-title">{t.publications.pageTitle}</h1>
    <p>{t.publications.intro}</p>
    <div class="publication-archive-legend" aria-label={t.publications.pageTitle}>
      <span>{t.publications.peerReviewedTitle} / {peerReviewedCount}</span>
      <span>{t.publications.technicalReportsTitle} / {technicalReportCount}</span>
    </div>
  </section>

  <Section id="peer-reviewed" className="publication-archive-section" eyebrow={`${t.publications.peerReviewedTitle} / ${peerReviewedCount}`} title={t.publications.peerReviewedTitle} intro={t.publications.empty}>
    {
      peerReviewed.length > 0 ? (
        <div class="publication-list">
          {peerReviewed.map((publication) => <PublicationItem publication={publication} lang={lang} labels={t.publications.labels} />)}
        </div>
      ) : (
        <p class="publication-empty">{t.publications.empty}</p>
      )
    }
  </Section>

  <Section id="technical-reports" className="publication-archive-section" eyebrow={`${t.publications.technicalReportsTitle} / ${technicalReportCount}`} title={t.publications.technicalReportsTitle} intro={t.publications.support}>
    <div class="publication-list">
      {technicalReports.map((publication) => <PublicationItem publication={publication} lang={lang} labels={t.publications.labels} />)}
    </div>
  </Section>
</div>
