---
import Navbar from '../components/Navbar.astro';
import VisualBackground from '../components/VisualBackground.astro';
import { profile } from '../data/profile';
import { getCopy, getPath, type Lang, type PageKey } from '../i18n';
import '../styles/global.css';

interface Props {
  lang: Lang;
  page: PageKey;
  title?: string;
  description?: string;
}

const { lang, page, title, description } = Astro.props as Props;
const t = getCopy(lang);
const pageTitle = title ?? t.meta.siteTitle;
const pageDescription = description ?? t.meta.description;
const canonical = Astro.site ? new URL(getPath(lang, page), Astro.site).toString() : Astro.url.href;
const alternateEn = Astro.site ? new URL(getPath('en', page), Astro.site).toString() : getPath('en', page);
const alternateZh = Astro.site ? new URL(getPath('zh', page), Astro.site).toString() : getPath('zh', page);
---

<!doctype html>
<html lang={t.htmlLang} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <meta name="theme-color" content="#050505" />
    <script is:inline>
      (() => {
        try {
          const storedTheme = localStorage.getItem('szdTheme');
          const theme = storedTheme === 'light' ? 'light' : 'dark';
          document.documentElement.dataset.theme = theme;
          document.documentElement.style.colorScheme = theme;
        } catch {
          document.documentElement.dataset.theme = 'dark';
          document.documentElement.style.colorScheme = 'dark';
        }

        const isHomePath = ['/', '/index.html', '/zh/', '/zh', '/zh/index.html'].includes(location.pathname);
        try {
          if (isHomePath) {
            const entered = sessionStorage.getItem('szdShaderEntered') === 'true';
            document.documentElement.classList.toggle('world-gate-session-entered', entered);
            document.documentElement.classList.toggle('world-gate-pending', !entered);
          }
        } catch {
          if (isHomePath) document.documentElement.classList.add('world-gate-pending');
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=JetBrains+Mono:wght@400;500;600&family=Noto+Serif+SC:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <noscript><style>.world-shader-gate{display:none!important}</style></noscript>
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={alternateEn} />
    <link rel="alternate" hreflang="zh-CN" href={alternateZh} />
    <link rel="alternate" hreflang="x-default" href={alternateEn} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={t.meta.siteTitle} />
    <meta name="twitter:card" content="summary" />
    <meta name="author" content={profile.nameEn} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">{t.common.skipToContent}</a>
    <VisualBackground />
    <Navbar lang={lang} page={page} />
    <main id="main-content">
      <slot />
    </main>
    <footer class="site-footer">
      <p>© {new Date().getFullYear()} {lang === 'zh' ? profile.nameZh : profile.nameEn}. {t.common.builtWith}</p>
    </footer>
  </body>
</html>
