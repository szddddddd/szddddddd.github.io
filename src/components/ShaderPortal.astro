---
import '../styles/shader-portal.css';

interface Props {
  title: string;
  subtitle: string;
  actionLabel?: string;
  actionHref?: string;
  kicker?: string;
  variant?: 'compact' | 'large';
  class?: string;
}

const {
  title,
  subtitle,
  actionLabel,
  actionHref,
  kicker = 'Raymarch / SDF WebGL study',
  variant = 'compact',
} = Astro.props as Props;
const className = (Astro.props as Props).class ?? '';
const titleId = `shader-portal-title-${variant}-${title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
---

<article
  class:list={['shader-portal', `shader-portal-${variant}`, 'reveal-block', className]}
  data-shader-portal
  data-shader-portal-variant={variant}
  data-shader-portal-state="idle"
  aria-labelledby={titleId}
>
  <div class="shader-portal-stage" aria-hidden="true">
    <div class="shader-portal-fallback" aria-hidden="true"></div>
    <canvas class="shader-portal-canvas" aria-hidden="true" role="presentation"></canvas>
    <div class="shader-portal-vignette" aria-hidden="true"></div>
    <span class="shader-portal-stage-label">local shader · no iframe</span>
  </div>

  <div class="shader-portal-body">
    <p class="shader-portal-kicker">{kicker}</p>
    <div class="shader-portal-copy">
      <h2 id={titleId}>{title}</h2>
      <p>{subtitle}</p>
    </div>
    {
      actionHref && actionLabel && (
        <a class="button button-secondary shader-portal-action" href={actionHref}>
          <span>{actionLabel}</span>
          <span aria-hidden="true">→</span>
        </a>
      )
    }
  </div>
</article>

<script>
  import '../scripts/shader-portal';
</script>
